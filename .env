# ============================================================
# DIRETÓRIOS
# ============================================================

# Pasta onde ficam os vídeos originais aguardando processamento.
DIR_ENTRADA=/home/user/Videos/gravado

# Pasta de saída. Para cada vídeo processado, será criado um
# subdiretório aqui com o mesmo nome do vídeo (sem extensão),
# contendo o vídeo com a voz alterada e o arquivo de legendas.
DIR_SAIDA=/home/user/Videos/final

# Pasta para onde o vídeo original é movido após ser processado
# com sucesso. Serve como histórico do que já foi processado.
DIR_BACKUP=/home/user/Videos/processado

# ============================================================
# PITCH MALE (alteração de tom de voz)
# ============================================================

# Fator de transposição de pitch aplicado pelo filtro rubberband do ffmpeg.
# Calculado como: 2^(semitons / 12)
# Valores de referência:
#   -1 semitom  → 0.9439  (leve)
#   -2 semitons → 0.8909  (padrão)
#   -3 semitons → 0.8409  (grave)
#   -4 semitons → 0.7937  (muito grave)
PITCH_FATOR=0.8909

# ============================================================
# EQUALIZAÇÃO — AQUECIMENTO DE GRAVES
# Reforça frequências baixas para dar mais corpo à voz.
# ============================================================

# Frequência central do reforço de graves, em Hz.
# Valores típicos: 80–200 Hz.
EQ_GRAVES_FREQ=150

# Largura da faixa de frequência afetada, em Hz.
# Quanto maior, mais frequências vizinhas também são reforçadas.
EQ_GRAVES_WIDTH=100

# Ganho aplicado na faixa de graves, em dB.
# Valores positivos reforçam; negativos atenuam.
EQ_GRAVES_GAIN=2

# ============================================================
# EQUALIZAÇÃO — CORTE ANTI-METÁLICO
# Remove a faixa de frequência responsável pelo som metálico
# gerado pelo pitch shifting.
# ============================================================

# Frequência central do corte anti-metálico, em Hz.
# A faixa 2.000–5.000 Hz costuma causar o efeito metálico.
EQ_METAL_FREQ=3500

# Largura da faixa de frequência afetada pelo corte, em Hz.
EQ_METAL_WIDTH=1000

# Ganho do corte, em dB. Deve ser negativo para atenuar a faixa.
EQ_METAL_GAIN=-3

# ============================================================
# TRANSCRIÇÃO (Whisper)
# ============================================================

# Modelo do Whisper usado para transcrever o áudio e gerar o
# arquivo de legendas (.srt). Modelos maiores são mais precisos,
# porém mais lentos e consomem mais memória.
# Opções: tiny | base | small | medium | large
WHISPER_MODEL=small

# ============================================================
# RELATÓRIO DE PALAVRAS (report.txt)
# ============================================================

# Lista de palavras a monitorar na transcrição, separadas por vírgula.
# O script vai procurar cada palavra no texto das legendas e registrar
# o tempo em que aparecem no arquivo report.txt.
PALAVRAS_FILTRO=corta,bosta,coleguinha

# ============================================================
# PALAVRAS EXCLUÍDAS DO YOUTUBE.txt
# ============================================================

# Lista de palavras que NÃO devem aparecer no YOUTUBE.txt,
# separadas por vírgula. São removidas das palavras-chave,
# dos conceitos e de qualquer sentença usada no título e na descrição.
PALAVRAS_EXCLUIR=merda,corta,coleguinha,eu
